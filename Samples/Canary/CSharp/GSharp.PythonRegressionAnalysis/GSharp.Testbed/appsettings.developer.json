{
  "Plugins": {
    "Folder": ".\\",

    "KeyedDataProviders": {
      "CanaryLabs": {
        "Assembly": "GHost.GSharp.Plugins.CanaryLabs.dll",
        "EventProvider": {
          "Settings": {
            // The number of milliseconds between each check of the Canary Live Data pipeline
            // for new data events. This check makes a call to the Canary Read Views API.
            "EventPollInterval": 5010,
            "ClientId": "GSharp.PythonRegressionAnalysis",
            "Historians": [
              "NotNeededForTestbed"
            ]
          }
        },
        "PointProvider": {
          "Settings": {
            "ClientId": "GSharp.PythonRegressionAnalysis",
            "Historians": [
              "NotNeededForTestbed"
            ]
          }
        }
      }
    }
  },

  "CanaryLabs": {
    "Servers": {
      "DEV-Canary2025": {
        "Host": "DEV-Canary2025",
        "TlsTrustMode": "SystemTrust",
        "ApiToken": "11111111-2222-3333-4444-555555555555",
        "ApiTokenEncryption": "None",
        "ViewsApiPort": 55236,
        "ViewsApiVersion": "v2",
        "StoreApiPort": 55293,
        "StoreApiVersion": "v1",
        "LiveDataConsolidationThreshold": 20,
        "LiveDataTokenMaxTagCount": 1000
      }
    }
  }
}
